{
  "name": "copilot-command-centre",
  "displayName": "Copilot Command Centre",
  "description": "A command centre for your GitHub Copilot agents — soldier companions, a routing @army chat participant, and one-click agent scaffolding.",
  "version": "0.1.0",
  "publisher": "copilot-command-centre",
  "license": "MIT",
  "engines": {
    "vscode": "^1.96.0"
  },
  "categories": ["AI", "Chat", "Other"],
  "keywords": ["copilot", "agents", "chat", "mascot", "workshop"],
  "main": "./out/extension.js",
  "activationEvents": ["onStartupFinished"],
  "contributes": {
    "chatParticipants": [
      {
        "id": "copilot-command-centre.army",
        "name": "army",
        "fullName": "Copilot Command Centre",
        "description": "Hand the army a task — the Captain routes it to the right soldier",
        "isSticky": true,
        "commands": [
          { "name": "roster", "description": "List every agent in the army" },
          { "name": "recruit", "description": "Scaffold a brand-new agent" }
        ]
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "commandCentre",
          "title": "Copilot Command Centre",
          "icon": "media/squad-icon.svg"
        }
      ]
    },
    "views": {
      "commandCentre": [
        { "id": "commandCentre.roster", "name": "Army", "icon": "media/squad-icon.svg" },
        { "id": "commandCentre.skills", "name": "Skills" }
      ]
    },
    "viewsWelcome": [
      {
        "view": "commandCentre.roster",
        "contents": "This workspace has no Copilot Command Centre yet.\n\nDeploy a full army of agents into `.github/` with one click.\n[Set Up the Army](command:commandCentre.setup)"
      }
    ],
    "commands": [
      { "command": "commandCentre.setup", "title": "Set Up the Army in This Workspace", "category": "Copilot Command Centre", "icon": "$(rocket)" },
      { "command": "commandCentre.recruit", "title": "Recruit a New Agent", "category": "Copilot Command Centre", "icon": "$(add)" },
      { "command": "commandCentre.refresh", "title": "Refresh the Army", "category": "Copilot Command Centre", "icon": "$(refresh)" },
      { "command": "commandCentre.openAgent", "title": "Open Agent File", "category": "Copilot Command Centre", "icon": "$(go-to-file)" },
      { "command": "commandCentre.briefAgent", "title": "Brief the Army", "category": "Copilot Command Centre", "icon": "$(comment-discussion)" },
      { "command": "commandCentre.askSquad", "title": "Ask the Centre (@army)", "category": "Copilot Command Centre", "icon": "$(comment-discussion)" },
      { "command": "commandCentre.runSkill", "title": "Run Skill", "category": "Copilot Command Centre" }
    ],
    "menus": {
      "view/title": [
        { "command": "commandCentre.setup", "when": "view == commandCentre.roster", "group": "navigation@0" },
        { "command": "commandCentre.askSquad", "when": "view == commandCentre.roster", "group": "navigation@1" },
        { "command": "commandCentre.recruit", "when": "view == commandCentre.roster", "group": "navigation@3" },
        { "command": "commandCentre.refresh", "when": "view == commandCentre.roster", "group": "navigation@4" }
      ],
      "view/item/context": [
        { "command": "commandCentre.briefAgent", "when": "view == commandCentre.roster && viewItem == agent", "group": "inline@1" },
        { "command": "commandCentre.openAgent", "when": "view == commandCentre.roster && viewItem == agent", "group": "inline@2" }
      ]
    },
    "walkthroughs": [
      {
        "id": "commandCentre.gettingStarted",
        "title": "Assemble Your Copilot Command Centre",
        "description": "Deploy an army of custom GitHub Copilot agents and put them to work.",
        "steps": [
          {
            "id": "meet",
            "title": "Meet the army",
            "description": "Open the Army sidebar and meet your six soldiers — each with a live status.\n[Open the Army Sidebar](command:workbench.view.extension.commandCentre)",
            "media": { "markdown": "walkthrough/01-meet.md" }
          },
          {
            "id": "setup",
            "title": "Deploy the army",
            "description": "Scaffold the agent files into this workspace's `.github/` folder.\n[Set Up the Army](command:commandCentre.setup)",
            "media": { "markdown": "walkthrough/02-setup.md" }
          },
          {
            "id": "ask",
            "title": "Put them to work",
            "description": "Open Copilot Chat and hand the army a mission with `@army`.\n[Ask the Centre](command:commandCentre.askSquad)",
            "media": { "markdown": "walkthrough/03-ask.md" }
          },
          {
            "id": "recruit",
            "title": "Recruit your own agent",
            "description": "Build a brand-new teammate, tuned to your project.\n[Recruit an Agent](command:commandCentre.recruit)",
            "media": { "markdown": "walkthrough/04-recruit.md" }
          }
        ]
      }
    ]
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "vscode:prepublish": "tsc -p ./"
  },
  "devDependencies": {
    "@types/node": "^20.x",
    "@types/vscode": "^1.96.0",
    "typescript": "^5.6.0"
  }
}
